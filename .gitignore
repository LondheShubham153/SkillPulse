# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Local env files
.env
.env.local

# SSH / certs — never commit
*.pem
*.key

# Logs
*.log

# Terraform safety net — `terraform/` has its own .gitignore, but if anyone runs
# terraform from the wrong cwd these guard rails catch the stray output.
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform/
